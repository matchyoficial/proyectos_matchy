	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>Google Login</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.694566552502-a9n0bno9dm7lle860mcsr9n80129nfe0</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Matchy necesita acceso a tu cámara para validar tu identidad (Check Azul) y tomar fotos para tu perfil.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>Matchy necesita tu ubicación para actualizar el radar de lugares recomendados y citas cercanas.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Matchy usa tu ubicación precisa para encontrar citas cercanas a ti en el radar y validar tu asistencia al lugar de encuentro.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Matchy requiere acceso al micrófono para el correcto funcionamiento del motor de la cámara al verificar tu perfil.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Matchy requiere acceso a tu ubicación para validar tu asistencia a las citas en los lugares aliados.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Matchy requiere acceso a tu galería de fotos para que puedas seleccionar y subir imágenes a tu perfil de citas.</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
